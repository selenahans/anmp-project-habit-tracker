<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <import type="com.example.habittracker.R" />

        <variable
            name="habit"
            type="com.example.habittracker.model.Habit" />

        <variable
            name="listener"
            type="com.example.habittracker.view.HabitClickListener" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHabit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="6dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="7dp"
            app:cardElevation="2dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeColor="#E1E1E1"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="165dp">

                <View
                    android:id="@+id/completedLine"
                    android:layout_width="3dp"
                    android:layout_height="0dp"
                    android:background="#5DBB6D"
                    android:visibility="@{habit.currentProgress >= habit.goal ? View.VISIBLE : View.GONE}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardIcon"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginTop="14dp"
                    app:cardBackgroundColor="#F0EAFF"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/imgHabit"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@{habit.name}"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/exercise"
                        tools:src="@drawable/exercise" />

                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/titleContainer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toStartOf="@id/statusProgress"
                    app:layout_constraintStart_toEndOf="@id/cardIcon"
                    app:layout_constraintTop_toTopOf="@id/cardIcon">

                    <TextView
                        android:id="@+id/txtTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:onClick="@{() -> listener.onTitleClick(habit)}"
                        android:text="@{habit.name}"
                        android:textColor="#303030"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        tools:text="Drink Water" />

                    <TextView
                        android:id="@+id/txtCompletedCheck"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:text="✓"
                        android:textColor="#55AC63"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:visibility="@{habit.currentProgress >= habit.goal ? View.VISIBLE : View.GONE}" />

                </LinearLayout>

                <TextView
                    android:id="@+id/txtDesc"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="3dp"
                    android:layout_marginEnd="8dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="@{habit.description}"
                    android:textColor="#777777"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toStartOf="@id/statusProgress"
                    app:layout_constraintStart_toEndOf="@id/cardIcon"
                    app:layout_constraintTop_toBottomOf="@id/titleContainer"
                    tools:text="Stay hydrated throughout the day" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/statusProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="13dp"
                    android:layout_marginEnd="13dp"
                    android:visibility="@{habit.currentProgress >= habit.goal ? View.GONE : View.VISIBLE}"
                    app:cardBackgroundColor="#EFEFEF"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="9dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="9dp"
                        android:paddingBottom="4dp"
                        android:text="In Progress"
                        android:textColor="#555555"
                        android:textSize="10sp" />

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/statusCompleted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="13dp"
                    android:layout_marginEnd="13dp"
                    android:visibility="@{habit.currentProgress >= habit.goal ? View.VISIBLE : View.GONE}"
                    app:cardBackgroundColor="#58A75E"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="9dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="9dp"
                        android:paddingBottom="4dp"
                        android:text="Completed"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp" />

                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/txtProgressLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginTop="16dp"
                    android:text="Progress"
                    android:textColor="#777777"
                    android:textSize="11sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardIcon" />

                <TextView
                    android:id="@+id/txtProgressRatio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="14dp"
                    android:text='@{String.valueOf(habit.currentProgress) + " / " + String.valueOf(habit.goal) + " " + habit.unit}'
                    android:textColor="#3A3A3A"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/txtProgressLabel"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/txtProgressLabel"
                    tools:text="3 / 8 glasses" />

                <ProgressBar
                    android:id="@+id/progressPurple"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="7dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginTop="7dp"
                    android:layout_marginEnd="14dp"
                    android:max="@{habit.goal}"
                    android:progress="@{habit.currentProgress}"
                    android:progressBackgroundTint="#E7DAFF"
                    android:progressTint="#6C00FF"
                    android:visibility="@{habit.currentProgress >= habit.goal ? View.INVISIBLE : View.VISIBLE}"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/txtProgressLabel" />

                <ProgressBar
                    android:id="@+id/progressGreen"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="7dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginTop="7dp"
                    android:layout_marginEnd="14dp"
                    android:max="@{habit.goal}"
                    android:progress="@{habit.currentProgress}"
                    android:progressBackgroundTint="#D5EED9"
                    android:progressTint="#58B268"
                    android:visibility="@{habit.currentProgress >= habit.goal ? View.VISIBLE : View.INVISIBLE}"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/txtProgressLabel" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMinus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginTop="9dp"
                    android:layout_marginEnd="7dp"
                    android:layout_marginBottom="11dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:onClick="@{() -> listener.onMinusClick(habit)}"
                    android:padding="0dp"
                    android:text="−"
                    android:textAllCaps="false"
                    android:textColor="#777777"
                    android:textSize="19sp"
                    app:backgroundTint="#F0F0F0"
                    app:cornerRadius="18dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btnPlus"
                    app:layout_constraintTop_toBottomOf="@id/progressPurple" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPlus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginTop="9dp"
                    android:layout_marginEnd="13dp"
                    android:layout_marginBottom="11dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:onClick="@{() -> listener.onPlusClick(habit)}"
                    android:padding="0dp"
                    android:text="+"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="19sp"
                    app:backgroundTint="#6C00FF"
                    app:cornerRadius="18dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/progressPurple" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>